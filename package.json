{
  "name": "finance-dashboard-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run db:prepare",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:sync-schema": "node scripts/switch-prisma-schema.mjs",
    "db:prepare": "npm run db:sync-schema && prisma generate",
    "db:generate": "npm run db:prepare",
    "db:migrate": "npm run db:sync-schema && prisma migrate dev",
    "db:push": "npm run db:sync-schema && prisma db push",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "next": "15.2.0",
    "next-auth": "5.0.0-beta.25",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "prisma": "^6.4.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
