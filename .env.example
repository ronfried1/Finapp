# Core
# Set APP_DB_PROVIDER to "postgresql" or "sqlite"
APP_DB_PROVIDER="postgresql"

# PostgreSQL example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_dashboard?schema=public"
# SQLite example (path is relative to prisma/schema.prisma):
# DATABASE_URL="file:./dev.db"
APP_ENCRYPTION_KEY_BASE64="REPLACE_WITH_32_BYTE_BASE64_KEY"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_SECRET"

# Google OAuth
AUTH_GOOGLE_ID="REPLACE"
AUTH_GOOGLE_SECRET="REPLACE"

# Optional app lock
APP_PASSCODE_PEPPER="REPLACE_WITH_LONG_RANDOM_STRING"

# Cron endpoint protection
CRON_SHARED_SECRET="REPLACE_WITH_RANDOM_SECRET"

# Runtime
NODE_ENV="development"

# Scraper runtime
# true = mock data, false = live bank/card scraping
USE_SCRAPER_MOCK="true"
# Optional: set live scraper history lookback (days)
SCRAPER_START_DAYS="365"
# Optional debugging in local chrome automation
SCRAPER_SHOW_BROWSER="false"
